# ==========================================================
# KRISHI SAKHI — BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# ==========================================================

# Supabase (Database, Auth, S3 Storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dify (RAG Chatbot & Workflow)
DIFY_API_URL=http://localhost/v1
DIFY_API_KEY=app-xxx

# LLM Providers
GROQ_API_KEY=gsk_xxx
OPENROUTER_API_KEY=sk-or-xxx

# Vector DB (Qdrant Cloud)
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
# Optional backend-side Qdrant enrichment. Dify performs primary RAG retrieval.
QDRANT_DIRECT_SEARCH_ENABLED=false

# ElevenLabs (optional — unused, replaced by gTTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ML Service URLs (defaults work for local development)
# SOIL_CLASSIFIER_URL=http://localhost:8001
# CROP_RECOMMENDER_URL=http://localhost:8002
# PRICE_FORECASTER_URL=http://localhost:8003
# PLANT_DISEASE_CLASSIFIER_URL=http://localhost:8004
# TRANSCRIBER_URL=http://localhost:8005

# Server Config
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development
