# ==========================================================
# KRISHI SAKHI — FRONTEND ENVIRONMENT VARIABLES
# All vars must be prefixed with VITE_ for Vite to expose them.
# Copy this file to .env and fill in your values.
# ==========================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend FastAPI base URL
# Local development (laptop browser):
VITE_API_BASE_URL=http://localhost:8000
# Phone testing on same Wi-Fi — replace with your laptop's LAN IP shown in backend startup log:
# VITE_API_BASE_URL=https://192.168.x.x:8000

# Dify (optional — legacy direct frontend usage, now routed via backend)
# VITE_DIFY_API_URL=http://localhost/v1
# VITE_DIFY_CHATBOT_API_KEY=app-xxx
