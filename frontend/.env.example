# ==========================================================
# KRISHI SAKHI — FRONTEND ENVIRONMENT VARIABLES
# All vars must be prefixed with VITE_ for Vite to expose them.
# Copy this file to .env and fill in your values.
# ==========================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend FastAPI base URL
# Optional for most local/LAN setups:
# - If omitted, the frontend derives the backend host from the current app URL
#   and targets port 8000 automatically.
# - Set it only when your backend is on a different host, port, or tunnel.
# VITE_API_BASE_URL=http://localhost:8000

# Dify (optional — legacy direct frontend usage, now routed via backend)
# VITE_DIFY_API_URL=http://localhost/v1
# VITE_DIFY_CHATBOT_API_KEY=app-xxx
